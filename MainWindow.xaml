<Window x:Class="RZDTrainer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🚂 Тренажер составителя поездов РЖД" 
        Height="700" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryColor" Color="#1E3A5F"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#2E7D32"/>
        <SolidColorBrush x:Key="ErrorColor" Color="#C62828"/>
        <SolidColorBrush x:Key="WarningColor" Color="#FF8F00"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#F5F5F5"/>
    </Window.Resources>

    <Grid Margin="15" Background="{StaticResource BackgroundColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка (ОДИН РАЗ) -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryColor}" CornerRadius="10" Padding="15" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🚂" FontSize="28" Margin="0,0,10,0"/>
                    <TextBlock Text="ТРЕНАЖЕР СОСТАВИТЕЛЯ ПОЕЗДОВ" FontSize="18" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="SelectScenarioButton" Content="📋" Width="40" Height="40" 
                            FontSize="20" Click="SelectScenarioButton_Click" ToolTip="Выбрать сценарий"
                            Background="White" BorderThickness="0" Cursor="Hand" Foreground="Black" Margin="0,0,10,0"/>
                    <Button x:Name="SettingsButton" Content="⚙️" Width="40" Height="40" 
                            FontSize="20" Click="SettingsButton_Click" ToolTip="Выбрать микрофон"
                            Background="White" BorderThickness="0" Cursor="Hand" Foreground="Black"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Статус микрофона -->
        <TextBlock x:Name="MicStatusText" Grid.Row="1" FontSize="12" Foreground="Gray"
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- Название сценария -->
        <Border Grid.Row="2" Background="#E0E0E0" CornerRadius="8" Padding="8" Margin="0,5">
            <TextBlock x:Name="TitleText" FontSize="14" FontWeight="Bold" TextWrapping="Wrap"/>
        </Border>

        <!-- Текст сценария -->
        <Border Grid.Row="3" Background="#FFF8E1" CornerRadius="8" Padding="12" Margin="0,10">
            <TextBlock x:Name="ScenarioText" FontSize="14" TextWrapping="Wrap"/>
        </Border>

        <!-- Кнопка микрофона (Push-to-Talk) -->
        <Grid Grid.Row="4" Margin="0,15">
            <Button x:Name="MicrophoneButton" Width="140" Height="90" HorizontalAlignment="Center"
                    Background="#D32F2F" Foreground="White" FontSize="14" FontWeight="Bold"
                    PreviewMouseLeftButtonDown="MicrophoneButton_PreviewMouseLeftButtonDown"
                    PreviewMouseLeftButtonUp="MicrophoneButton_PreviewMouseLeftButtonUp"
                    Cursor="Hand" BorderThickness="0">
                <StackPanel>
                    <TextBlock x:Name="MicIcon" Text="🎤" FontSize="36"/>
                    <TextBlock x:Name="MicButtonText" Text="ЗАЖМИТЕ" FontSize="12" Margin="0,5,0,0"/>
                </StackPanel>
            </Button>

            <TextBlock x:Name="RecordingIndicator" Text="⏺ ЗАПИСЬ" 
                       Foreground="Red" FontWeight="Bold" FontSize="12"
                       HorizontalAlignment="Left" VerticalAlignment="Center" Margin="150,0,0,0"
                       Visibility="Collapsed"/>
        </Grid>

        <!-- Живая транскрипция -->
        <Border Grid.Row="5" Background="White" CornerRadius="8" Padding="10" Margin="0,10"
                BorderBrush="#CCCCCC" BorderThickness="1">
            <TextBlock x:Name="LiveText" FontSize="16" FontStyle="Italic" 
                       TextWrapping="Wrap" Foreground="#666666"
                       Text="Нажмите и удерживайте кнопку микрофона..."/>
        </Border>

        <!-- Статусная строка -->
        <TextBlock x:Name="StatusText" Grid.Row="6" FontSize="12" Foreground="#555555"
                   HorizontalAlignment="Center" Margin="0,10,0,0"/>

        <!-- Панель результата (Popup внутри Grid) -->
        <Popup x:Name="ResultPopup" PlacementTarget="{Binding ElementName=MicrophoneButton}"
               Placement="Bottom" StaysOpen="False" Width="550" Height="450"
               Grid.Row="0" Grid.RowSpan="7" IsOpen="False">
            <Border Background="White" CornerRadius="10" BorderBrush="#DDDDDD" BorderThickness="1"
                    Padding="15" Margin="0,10">
                <StackPanel>
                    <TextBlock x:Name="VerdictText" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <TextBlock Text="Процент совпадения:" FontWeight="Bold" Margin="0,5"/>
                    <ProgressBar x:Name="ScoreProgressBar" Height="25" Minimum="0" Maximum="100"/>
                    <TextBlock x:Name="ScoreText" HorizontalAlignment="Right" Margin="0,2,0,0"/>

                    <TextBlock Text="Ваша фраза:" FontWeight="Bold" Margin="0,10,0,5"/>
                    <Border Background="#F0F0F0" CornerRadius="5" Padding="8">
                        <TextBlock x:Name="UserPhraseText" TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock Text="Правильная фраза:" FontWeight="Bold" Margin="0,10,0,5"/>
                    <Border Background="#E8F5E9" CornerRadius="5" Padding="8">
                        <TextBlock x:Name="CanonicalText" TextWrapping="Wrap"/>
                    </Border>

                    <Expander Header="Подробнее" Margin="0,10,0,0">
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Прямое совпадение:" Grid.Row="0" Grid.Column="0"/>
                            <TextBlock x:Name="DirectMatchText" Grid.Row="0" Grid.Column="1"/>
                            <TextBlock Text="Ключевые слова:" Grid.Row="1" Grid.Column="0"/>
                            <TextBlock x:Name="KeywordMatchText" Grid.Row="1" Grid.Column="1"/>
                            <TextBlock Text="Нейросеть:" Grid.Row="2" Grid.Column="0"/>
                            <TextBlock x:Name="NeuralMatchText" Grid.Row="2" Grid.Column="1"/>
                        </Grid>
                    </Expander>

                    <TextBlock x:Name="ExtraInfoText" Margin="0,10" FontStyle="Italic" TextWrapping="Wrap" Foreground="#666666"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                        <Button x:Name="NextButton" Content="▶ ДАЛЕЕ" Width="100" Margin="5" 
                                Click="NextButton_Click" Background="#1E3A5F" Foreground="White"/>
                        <Button x:Name="RepeatButton" Content="🔄 ПОВТОРИТЬ" Width="100" Margin="5" 
                                Click="RepeatButton_Click" Background="#757575" Foreground="White"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>