<Window x:Class="RZDTrainer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🚂 Тренажёр составителя поездов РЖД"
        Height="780" Width="940" MinHeight="640" MinWidth="760"
        WindowStartupLocation="CenterScreen"
        Background="#EEF1F5"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryColor" Color="#13294B"/>
        <SolidColorBrush x:Key="AccentColor" Color="#D32F2F"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#2E7D32"/>
        <SolidColorBrush x:Key="ErrorColor" Color="#C62828"/>
        <SolidColorBrush x:Key="WarningColor" Color="#EF6C00"/>
        <SolidColorBrush x:Key="CardColor" Color="White"/>
        <SolidColorBrush x:Key="MutedColor" Color="#6B7785"/>

        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#13294B" Offset="0"/>
            <GradientStop Color="#274C77" Offset="1"/>
        </LinearGradientBrush>

        <!-- Мягкая тень для карточек -->
        <DropShadowEffect x:Key="SoftShadow" BlurRadius="14" ShadowDepth="2"
                          Direction="270" Opacity="0.16" Color="#33415A"/>

        <!-- Плоская кнопка со скруглением -->
        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="9" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Круглая иконочная кнопка в шапке -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="#1F3A66"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="11">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2E5288"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ============ ШАПКА ============ -->
        <Border Grid.Row="0" Background="{StaticResource HeaderGradient}" CornerRadius="14"
                Padding="20,14" Effect="{StaticResource SoftShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🚂" FontSize="30" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="ТРЕНАЖЁР СОСТАВИТЕЛЯ ПОЕЗДОВ"
                                   FontSize="19" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Регламент переговоров · ОАО «РЖД»"
                                   FontSize="12" Foreground="#AFC4E0" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="SelectScenarioButton" Content="📋" Style="{StaticResource IconButton}"
                            Click="SelectScenarioButton_Click" ToolTip="Выбрать сценарий" Margin="0,0,10,0"/>
                    <Button x:Name="SettingsButton" Content="⚙" Style="{StaticResource IconButton}"
                            Click="SettingsButton_Click" ToolTip="Выбрать микрофон"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Статус микрофона -->
        <Border Grid.Row="1" Background="#E3E9F2" CornerRadius="8" Padding="10,6" Margin="0,12,0,0"
                HorizontalAlignment="Center">
            <TextBlock x:Name="MicStatusText" FontSize="12" Foreground="{StaticResource MutedColor}"/>
        </Border>

        <!-- ============ КАРТОЧКА СЦЕНАРИЯ ============ -->
        <Border Grid.Row="2" Background="{StaticResource CardColor}" CornerRadius="14"
                Padding="20" Margin="0,14,0,0" Effect="{StaticResource SoftShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Заголовок + бейдж сложности -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TitleText" Grid.Column="0" FontSize="17" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryColor}" TextWrapping="Wrap"
                               VerticalAlignment="Center"/>
                    <Border x:Name="DifficultyBadge" Grid.Column="1" CornerRadius="20" Padding="14,6"
                            Background="{StaticResource MutedColor}" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock x:Name="DifficultyText" Text="Средний" Foreground="White"
                                   FontWeight="Bold" FontSize="12"/>
                    </Border>
                </Grid>

                <!-- Картинка + описание (со скроллом, если не помещается) -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,14,0,0">
                    <StackPanel>
                        <!-- Картинка сценария -->
                        <Border x:Name="ImageCard" CornerRadius="12" Margin="0,0,0,14"
                                Visibility="Collapsed" ClipToBounds="True"
                                BorderBrush="#DDE3EC" BorderThickness="1">
                            <Image x:Name="ScenarioImage" Stretch="Uniform" MaxHeight="240"
                                   HorizontalAlignment="Center"/>
                        </Border>

                        <!-- Подпись «Ситуация» -->
                        <TextBlock Text="СИТУАЦИЯ" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource MutedColor}" Margin="2,0,0,6"/>
                        <Border Background="#FFF8E6" CornerRadius="10" Padding="14"
                                BorderBrush="#F2E2B3" BorderThickness="1">
                            <TextBlock x:Name="ScenarioText" FontSize="14" TextWrapping="Wrap"
                                       Foreground="#4A3B12" LineHeight="20"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ============ КНОПКА МИКРОФОНА (Push-to-Talk) ============ -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Button x:Name="MicrophoneButton" Width="170" Height="96" HorizontalAlignment="Center"
                    Background="{StaticResource AccentColor}" Foreground="White"
                    PreviewMouseLeftButtonDown="MicrophoneButton_PreviewMouseLeftButtonDown"
                    PreviewMouseLeftButtonUp="MicrophoneButton_PreviewMouseLeftButtonUp"
                    Cursor="Hand" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="mb" Background="{TemplateBinding Background}" CornerRadius="18"
                                Effect="{StaticResource SoftShadow}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="mb" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="mb" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel>
                    <TextBlock x:Name="MicIcon" Text="🎤" FontSize="38" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="MicButtonText" Text="ЗАЖМИТЕ И ГОВОРИТЕ" FontSize="12"
                               FontWeight="Bold" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                    Background="#FDE7E7" CornerRadius="14" Padding="12,6"
                    x:Name="RecordingIndicator" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Fill="#D32F2F" VerticalAlignment="Center" Margin="0,0,7,0"/>
                    <TextBlock Text="ИДЁТ ЗАПИСЬ" Foreground="#C62828" FontWeight="Bold" FontSize="12"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ============ ЖИВАЯ ТРАНСКРИПЦИЯ ============ -->
        <Border Grid.Row="4" Background="{StaticResource CardColor}" CornerRadius="12" Padding="16"
                Margin="0,16,0,0" Effect="{StaticResource SoftShadow}">
            <StackPanel>
                <TextBlock Text="РАСПОЗНАНО" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource MutedColor}" Margin="0,0,0,6"/>
                <TextBlock x:Name="LiveText" FontSize="16"
                           TextWrapping="Wrap" Foreground="#90A0B0"
                           Text="Нажмите и удерживайте кнопку микрофона…"/>
            </StackPanel>
        </Border>

        <!-- Статусная строка -->
        <TextBlock x:Name="StatusText" Grid.Row="5" FontSize="12" Foreground="{StaticResource MutedColor}"
                   HorizontalAlignment="Center" Margin="0,12,0,0" Text="Готов к работе"/>

        <!-- ============ ПАНЕЛЬ РЕЗУЛЬТАТА ============ -->
        <Popup x:Name="ResultPopup" PlacementTarget="{Binding ElementName=MicrophoneButton}"
               Placement="Bottom" StaysOpen="False" Width="560"
               Grid.Row="0" Grid.RowSpan="6" IsOpen="False" AllowsTransparency="True">
            <Border Background="White" CornerRadius="14" BorderBrush="#DDE3EC" BorderThickness="1"
                    Padding="20" Margin="0,12" Effect="{StaticResource SoftShadow}">
                <StackPanel>
                    <Border x:Name="VerdictBanner" CornerRadius="10" Padding="12" Background="#EEF1F5">
                        <TextBlock x:Name="VerdictText" FontSize="20" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Процент совпадения" FontWeight="SemiBold" Margin="0,16,0,5"
                               Foreground="{StaticResource MutedColor}"/>
                    <Grid>
                        <ProgressBar x:Name="ScoreProgressBar" Height="26" Minimum="0" Maximum="100"
                                     Foreground="#2E7D32" Background="#E3E9F2" BorderThickness="0"/>
                        <TextBlock x:Name="ScoreText" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontWeight="Bold" FontSize="13" Foreground="#13294B"/>
                    </Grid>

                    <TextBlock Text="Ваша фраза" FontWeight="SemiBold" Margin="0,16,0,5"
                               Foreground="{StaticResource MutedColor}"/>
                    <Border Background="#F2F5F9" CornerRadius="8" Padding="12">
                        <TextBlock x:Name="UserPhraseText" TextWrapping="Wrap" FontSize="13"/>
                    </Border>

                    <TextBlock Text="Правильная фраза" FontWeight="SemiBold" Margin="0,12,0,5"
                               Foreground="{StaticResource MutedColor}"/>
                    <Border Background="#E8F5E9" CornerRadius="8" Padding="12">
                        <TextBlock x:Name="CanonicalText" TextWrapping="Wrap" FontSize="13" Foreground="#1B5E20"/>
                    </Border>

                    <Expander Header="Подробнее об оценке" Margin="0,14,0,0" Foreground="{StaticResource MutedColor}">
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Прямое совпадение" Grid.Row="0" Grid.Column="0" Margin="0,3"/>
                            <TextBlock x:Name="DirectMatchText" Grid.Row="0" Grid.Column="1" FontWeight="SemiBold"/>
                            <TextBlock Text="Ключевые слова" Grid.Row="1" Grid.Column="0" Margin="0,3"/>
                            <TextBlock x:Name="KeywordMatchText" Grid.Row="1" Grid.Column="1" FontWeight="SemiBold"/>
                            <TextBlock Text="Нейросеть" Grid.Row="2" Grid.Column="0" Margin="0,3"/>
                            <TextBlock x:Name="NeuralMatchText" Grid.Row="2" Grid.Column="1" FontWeight="SemiBold"/>
                        </Grid>
                    </Expander>

                    <TextBlock x:Name="ExtraInfoText" Margin="0,12,0,0" FontStyle="Italic"
                               TextWrapping="Wrap" Foreground="{StaticResource MutedColor}"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                        <Button x:Name="NextButton" Content="▶  ДАЛЕЕ" Width="130" Margin="6"
                                Click="NextButton_Click" Background="{StaticResource PrimaryColor}"
                                Style="{StaticResource FlatButton}"/>
                        <Button x:Name="RepeatButton" Content="🔄  ПОВТОРИТЬ" Width="130" Margin="6"
                                Click="RepeatButton_Click" Background="#607D8B"
                                Style="{StaticResource FlatButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
