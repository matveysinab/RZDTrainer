<Window x:Class="RZDTrainer.Views.ScenarioSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:RZDTrainer.Converters"
        Title="📋 Выбор сценария"
        Height="600" Width="660"
        WindowStartupLocation="CenterOwner"
        Background="#EEF1F5"
        FontFamily="Segoe UI">

    <Window.Resources>
        <conv:PathToImageConverter x:Key="PathToImage"/>
        <conv:DifficultyToBrushConverter x:Key="DiffToBrush"/>

        <SolidColorBrush x:Key="PrimaryColor" Color="#13294B"/>
        <SolidColorBrush x:Key="MutedColor" Color="#6B7785"/>

        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#13294B" Offset="0"/>
            <GradientStop Color="#274C77" Offset="1"/>
        </LinearGradientBrush>

        <DropShadowEffect x:Key="SoftShadow" BlurRadius="14" ShadowDepth="2"
                          Direction="270" Opacity="0.16" Color="#33415A"/>

        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Контейнер элемента списка -->
        <Style x:Key="ScenarioItem" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="row" Background="White" CornerRadius="12" Padding="10"
                                BorderBrush="#E3E9F2" BorderThickness="1">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="row" Property="Background" Value="#F5F8FC"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="row" Property="Background" Value="#EAF1FB"/>
                                <Setter TargetName="row" Property="BorderBrush" Value="#274C77"/>
                                <Setter TargetName="row" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="{StaticResource HeaderGradient}" CornerRadius="12"
                Padding="16,12" Effect="{StaticResource SoftShadow}">
            <TextBlock Text="📋  ВЫБОР СЦЕНАРИЯ ОБУЧЕНИЯ"
                       FontSize="16" FontWeight="Bold" Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Поиск -->
        <Border Grid.Row="1" Background="White" CornerRadius="9" Margin="0,12,0,10"
                BorderBrush="#E3E9F2" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="12,0,0,0"
                           Foreground="{StaticResource MutedColor}"/>
                <TextBox x:Name="SearchBox" Grid.Column="1" BorderThickness="0" Background="Transparent"
                         Padding="8,10" FontSize="13" VerticalContentAlignment="Center"
                         TextChanged="SearchBox_TextChanged"/>
            </Grid>
        </Border>

        <!-- Список сценариев -->
        <ListBox x:Name="ScenariosListBox" Grid.Row="2"
                 SelectionMode="Single"
                 Background="Transparent" BorderThickness="0"
                 ItemContainerStyle="{StaticResource ScenarioItem}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Номер сценария -->
                        <Border Grid.Column="0" Background="#13294B" CornerRadius="10"
                                Width="52" Height="52" Margin="0,0,12,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding Id}" Foreground="White" FontWeight="Bold"
                                       FontSize="13" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Миниатюра картинки (или заглушка) -->
                        <Border Grid.Column="1" Width="86" Height="52" CornerRadius="8"
                                Margin="0,0,12,0" ClipToBounds="True" Background="#E3E9F2"
                                VerticalAlignment="Center">
                            <Grid>
                                <TextBlock Text="🖼" FontSize="20" Foreground="#AAB6C4"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Image Source="{Binding ImageFullPath, Converter={StaticResource PathToImage}}"
                                       Stretch="UniformToFill"/>
                            </Grid>
                        </Border>

                        <!-- Название + описание + сложность -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14"
                                           Foreground="#13294B" TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding Context}" FontSize="11"
                                       Foreground="{StaticResource MutedColor}"
                                       TextWrapping="Wrap" MaxHeight="32" Margin="0,3,0,5"/>
                            <!-- Бейдж сложности -->
                            <Border CornerRadius="20" Padding="10,3" HorizontalAlignment="Left"
                                    Background="{Binding Difficulty, Converter={StaticResource DiffToBrush}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚡" FontSize="10" Foreground="White"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding DifficultyLabel}" Foreground="White"
                                               FontWeight="Bold" FontSize="11"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Индикатор выбранного -->
                        <TextBlock x:Name="SelectedIndicator" Grid.Column="3" Text="✅"
                                   FontSize="18" VerticalAlignment="Center" Margin="8,0,2,0"
                                   Visibility="Collapsed"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Кнопки -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="SelectButton" Content="✅  ВЫБРАТЬ" Width="140" Margin="0,0,10,0"
                    Click="SelectButton_Click" Background="#13294B" Style="{StaticResource FlatButton}"/>
            <Button x:Name="CancelButton" Content="❌  ОТМЕНА" Width="120"
                    Click="CancelButton_Click" Background="#607D8B" Style="{StaticResource FlatButton}"/>
        </StackPanel>
    </Grid>
</Window>
