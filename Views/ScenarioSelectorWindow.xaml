<Window x:Class="RZDTrainer.Views.ScenarioSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="📋 Выбор сценария" 
        Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="White">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#1E3A5F" CornerRadius="8" Padding="10" Margin="0,0,0,10">
            <TextBlock Text="📋 ВЫБОР СЦЕНАРИЯ ОБУЧЕНИЯ" 
                       FontSize="16" FontWeight="Bold" 
                       Foreground="White" 
                       HorizontalAlignment="Center"/>
        </Border>
        
        <!-- Поиск -->
        <TextBox x:Name="SearchBox" Grid.Row="1" 
                 Margin="0,0,0,10"
                 Padding="8"
                 FontSize="13"
                 TextChanged="SearchBox_TextChanged"/>
        
        <!-- Список сценариев -->
        <ListBox x:Name="ScenariosListBox" Grid.Row="2"
                 SelectionMode="Single"
                 Margin="0,0,0,10"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#DDDDDD" BorderThickness="0,0,0,1" Padding="10" Margin="0,2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Номер сценария -->
                            <Border Grid.Column="0" Background="#1E3A5F" CornerRadius="15" 
                                    Width="45" Height="45" Margin="0,0,15,0"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Id}" 
                                           Foreground="White" 
                                           FontWeight="Bold" 
                                           FontSize="14"
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                            
                            <!-- Название -->
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding Title}" 
                                           FontWeight="Bold" 
                                           FontSize="14"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Context}" 
                                           FontSize="11" 
                                           Foreground="Gray"
                                           TextWrapping="Wrap"
                                           MaxHeight="40"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                            
                            <!-- Индикатор выбранного -->
                            <TextBlock x:Name="SelectedIndicator" Grid.Column="2" 
                                       Text="✅" 
                                       FontSize="18"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <!-- Кнопки -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10">
            <Button x:Name="SelectButton" Content="✅ ВЫБРАТЬ" Width="120" Height="35" 
                    Margin="0,0,10,0" Click="SelectButton_Click"
                    Background="#1E3A5F" Foreground="White" 
                    FontWeight="Bold" Cursor="Hand"/>
            <Button x:Name="CancelButton" Content="❌ ОТМЕНА" Width="100" Height="35" 
                    Click="CancelButton_Click"
                    Background="#757575" Foreground="White" 
                    FontWeight="Bold" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>